{
  "name": "resume-builder",
  "version": "1.0.0",
  "description": "A Handlebars-based resume builder with PDF and DOCX export capabilities.",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=production node index.js",
    "dev:backend": "nodemon index.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "npm run build --prefix frontend"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "docx": "^9.0.0",
    "express": "^4.18.2",
    "express-handlebars": "^7.0.7",
    "handlebars": "^4.7.8",
    "html-to-docx": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^24.40.0",
    "quill": "^2.0.3",
    "react-quill": "^2.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
